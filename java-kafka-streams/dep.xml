<assembly
  xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2
  http://maven.apache.org/xsd/assembly-1.1.2.xsd">

  <!-- TODO: a jarjar format would be better -->
  <id>dep</id>
  <formats>
    <format>jar</format>
  </formats>
  <includeBaseDirectory>false</includeBaseDirectory>
    <fileSets>
        <fileSet>
            <directory>${basedir}/target/classes
            </directory>
            <outputDirectory>/</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${basedir}/src</directory>
            <outputDirectory>/src</outputDirectory>
        </fileSet>
    </fileSets>
  <dependencySets>
    <dependencySet>
      <outputDirectory>/</outputDirectory>
      <unpack>true</unpack>
      <scope>runtime</scope>
      <includes>
	      <include>org.apache.kafka:kafka-streams</include>
	      <include>org.apache.kafka:kafka-clients</include>
	      <include>commons-cli:commons-cli</include>
	      <include>commons-codec:commons-codec</include>
	      <include>org.slf4j:slf4j-reload4j</include>
	      <include>org.slf4j:slf4j-api</include>
	      <include>ch.qos.reload4j:reload4j</include>
	      <include>org.xerial.snappy:snappy-java</include>
	      <include>org.rocksdb:rocksdbjni</include>
	      <include>com.fasterxml.jackson.core:jackson-databind</include>
	      <include>com.fasterxml.jackson.core:jackson-core</include>
	      <include>com.fasterxml.jackson.core:jackson-annotations</include>
	      <include>com.mysql:mysql-connector-j</include>
	      <include>org.apache.commons:commons-lang3</include>
	      <include>org.apache.httpcomponents:httpclient</include>
	      <include>org.apache.httpcomponents:httpcore</include>
	      <include>org.apache.httpcomponents:httpcore-nio</include>
	      <include>commons-logging:commons-logging</include>
	      <include>org.apache.httpcomponents:httpasyncclient</include>
              <include>org.elasticsearch.client:elasticsearch-rest-client</include>
	      <include>co.elastic.clients:elasticsearch-java</include>
	      <include>jakarta.json:jakarta.json-api</include>
	      <include>io.opentelemetry:opentelemetry-api</include>
	      <include>io.opentelemetry:opentelemetry-context</include>
	      <include>org.eclipse.parsson:parsson</include>
	      <include>com.google.guava:guava</include>
	      <include>com.datastax.oss:java-driver-core</include>
	      <include>com.datastax.oss:java-driver-shaded-guava</include>
	      <include>com.datastax.oss:native-protocol</include>
	      <include>io.netty:netty-common</include>
	      <include>io.netty:netty-buffer</include>
	      <include>io.netty:netty-transport</include>
	      <include>io.netty:netty-resolver</include>
	      <include>io.netty:netty-handler</include>
	      <include>io.netty:netty-codec</include>
	      <include>com.typesafe:config</include>
	      <include>com.github.jnr:jnr-posix</include>
      </includes>
      <excludes>
      </excludes>
    </dependencySet>
  </dependencySets>
</assembly>
